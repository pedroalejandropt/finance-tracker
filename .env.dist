# ─── Auth ───────────────────────────────────────────────────────────────────
# Required. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
# Public URL of the app (used for OAuth callbacks and email links)
NEXTAUTH_URL=http://localhost:3000

# ─── AWS / DynamoDB ──────────────────────────────────────────────────────────
# Optional — omit to run in demo mode (in-memory data, no persistence)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# DynamoDB table names (must match tables created in your AWS account)
AWS_DYNAMODB_USERS_TABLE=finance-tracker-users
AWS_DYNAMODB_ACCOUNTS_TABLE=finance-tracker-accounts
AWS_DYNAMODB_STOCKS_TABLE=finance-tracker-stocks
AWS_DYNAMODB_RATES_TABLE=finance-tracker-rates
AWS_DYNAMODB_TRANSACTIONS_TABLE=finance-tracker-transactions
AWS_DYNAMODB_SNAPSHOTS_TABLE=finance-tracker-snapshots
AWS_DYNAMODB_BUDGETS_TABLE=finance-tracker-budgets

# ─── External APIs ───────────────────────────────────────────────────────────
# Optional — mock/fallback data used when keys are absent
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
# Open Exchange Rates: https://openexchangerates.org/account/app-ids
EXCHANGE_RATE_API_KEY=your-exchange-rate-key

# ─── OAuth Providers ─────────────────────────────────────────────────────────
# Optional — leave blank to disable Google / GitHub sign-in
# Google: https://console.cloud.google.com/ → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# GitHub: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── SMTP / Email ────────────────────────────────────────────────────────────
# Optional — required for email verification and password reset flows
# Leave blank to skip sending emails (registration still works, links are skipped)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Set to "true" for port 465 (implicit TLS), leave blank or "false" for STARTTLS
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
# Sender address shown in outgoing emails (defaults to SMTP_USER if omitted)
SMTP_FROM=noreply@example.com
